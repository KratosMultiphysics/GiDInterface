<?xml version="1.0" encoding="UTF-8"?>
<Materials>

    <Material n="DEMThermic-DefaultMaterial" MaterialType="DEMThermic" help="">
        <inputs>
			<parameter n="PARTICLE_DENSITY"            pn="Density"                     v="2500.0" type="double" unit_magnitude="Density"         units="kg/m^3" help="Density of the material (not bulk density)"/>
			<parameter n="YOUNG_MODULUS"               pn="Young Modulus"               v="1.0e5"  type="double" unit_magnitude="P"               units="Pa"     help="The Youngs Modulus of the material (not bulk stiffness)"/>
			<parameter n="POISSON_RATIO"               pn="Poisson Ratio"               v="0.20"   type="double" help="The Poissons Ratio of the material (not bulk Ratio)"/>
			<parameter n="CONDUCTIVITY"                pn="Thermal conductivity"        v="1000.0" type="double" unit_magnitude="Power/(L*Temp)"  units="W/(m*K)"/>
            <parameter n="SPECIFIC_HEAT"               pn="Specific heat"               v="100.0"  type="double" unit_magnitude="Energy/(M*Temp)" units="J/(kg*K)"/>
			<parameter n="FRICTION"                    pn="Friction angle"              v="30.0"   type="double" unit_magnitude="Angle"           units="deg" help="Particle friction angle (for Coulombs friction)"/>
			<parameter n="COEFFICIENT_OF_RESTITUTION"  pn="Coefficient of restitution"  v="0.2"    type="double" help=""/>
			<parameter n="PARTICLE_MATERIAL"           pn="Color"                       v="1"      type="integer"/>
			<parameter n="ROLLING_FRICTION"            pn="Rolling friction"            v="0.01"   type="double" help="Rolling friction"/>
			<parameter n="ROLLING_FRICTION_WITH_WALLS" pn="Rolling friction With Walls" v="0.01"   type="double" help="Rolling friction with walls"/>
			<parameter n="PARTICLE_SPHERICITY"         pn="Sphericity"                  v="1.0"    type="double" help="Particle sphericity"/>
        </inputs>
    </Material>

</Materials>
